# CloudBase Configuration（可选，用于云端持久化）
# 配置后即可使用腾讯云 CloudBase 文档型数据库持久化房间和玩家数据，
# 支持多设备/多会话联机。
# 获取地址：https://console.cloud.tencent.com/tcb
# 若不配置，应用会自动降级为本地 JSON 文件存储，数据保存在 ./data/ 目录下。
CLOUDBASE_ENV_ID=your-cloudbase-env-id
CLOUDBASE_API_KEY=your-cloudbase-server-api-key

# CORS 允许来源（生产环境建议配置为前端域名，多个用逗号分隔）
# 例如：https://lifecard.example.com,https://www.example.com
# 留空则默认允许所有来源（仅建议开发环境使用）
ALLOWED_ORIGINS=

# 前端独立部署时的后端 API 地址（例如 GitHub Pages + CloudBase 云函数后端）
# 本地开发或 CloudBase 一体化部署时留空，使用相对路径 /api/trpc
# VITE_API_URL=https://your-env-id.service.tcloudbase.com/api/trpc

# 路由模式
# - 一体化部署（CloudBase 静态托管 + 自定义域名）：留空，使用 BrowserRouter
# - 独立静态部署（GitHub Pages 等无 SPA 回退的场景）：设置为 hash
# VITE_ROUTER_TYPE=hash
