# CloudBase Configuration（数据库）
# 用于 EdgeOne Pages Cloud Functions 连接 CloudBase 数据库
# 获取地址：https://console.cloud.tencent.com/tcb
CLOUDBASE_ENV_ID=your-cloudbase-env-id
CLOUDBASE_API_KEY=your-cloudbase-server-api-key

# CORS 允许来源（生产环境建议配置为前端域名，多个用逗号分隔）
# EdgeOne Pages 方案：使用 EdgeOne Pages 默认域名
# GitHub Pages 方案：使用 GitHub Pages 域名
# 测试阶段可填 *，生产环境建议配置具体域名
ALLOWED_ORIGINS=

# 仅在前端独立部署时使用（例如 GitHub Pages 方案）
# EdgeOne Pages 方案留空，前端默认请求同域名 /api/trpc
# VITE_API_URL=https://your-env-id.service.tcloudbase.com/api/trpc

# 路由模式
# - EdgeOne Pages 方案：留空，使用 BrowserRouter
# - GitHub Pages 方案：设置为 hash
# VITE_ROUTER_TYPE=hash
