{
  "buildCommand": "npm run build:edgeone",
  "outputDirectory": "./dist/public",
  "installCommand": "npm install",
  "nodeVersion": "22.11.0",
  "rewrites": [
    {
      "source": "/api/*",
      "destination": "/api/:splat"
    },
    {
      "source": "/assets/*",
      "destination": "/assets/:splat"
    },
    {
      "source": "/*",
      "destination": "/index.html"
    }
  ]
}
